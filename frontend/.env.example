VITE_REOWN_PROJECT_ID=
VITE_API_URL=http://localhost:3001
# Required for ENS resolve / reverse lookup (Issue & Verify UI). Without this, ENS names cannot be resolved.
VITE_SEPOLIA_RPC_URL=
# Issue fee via Reown (eth_sendTransaction) before Hedera notarize — set recipient to enable
# VITE_ISSUE_PAYMENT_RECIPIENT=0xYourSepoliaAddress
# Amount in ETH (18 decimals). Default 0.001 if omitted.
# VITE_ISSUE_PAYMENT_AMOUNT_ETH=0.001
# Chain ID for eth_sendTransaction. Default: 11155111 (Sepolia).
# VITE_PAYMENT_CHAIN_ID=11155111